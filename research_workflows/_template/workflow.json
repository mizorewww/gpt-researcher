{
  "$schema": "../workflow.schema.json",
  "schemaVersion": 1,
  "name": "__WORKFLOW_NAME__",
  "description": "Evidence-first research workflow powered by configurable OpenCode agents, skills, and MCP servers.",
  "entryCommand": "run",
  "entryAgent": "research-coordinator",
  "requires": {
    "opencode": ">=1.17.15",
    "env": ["DEEPSEEK_API_KEY", "TAVILY_API_KEY"],
    "skills": ["evidence-triangulation"],
    "mcp": ["gpt-researcher-codex-long"]
  },
  "execution": {
    "defaultReplicas": 1,
    "maxReplicas": 3,
    "timeoutSeconds": 3000,
    "persistentServer": true
  },
  "security": {
    "allowedToolPatterns": [
      "skill",
      "task",
      "gpt-researcher-codex-long_*"
    ],
    "allowedAgents": [
      "research-coordinator",
      "source-researcher",
      "evidence-auditor"
    ],
    "agentToolPatterns": {
      "research-coordinator": ["skill", "task", "gpt-researcher-codex-long_*"],
      "source-researcher": ["skill", "gpt-researcher-codex-long_*"],
      "evidence-auditor": ["skill"]
    },
    "allowCommandShell": false
  },
  "inputSchema": "schemas/input.schema.json",
  "result": {
    "marker": "OPENCODE_WORKFLOW_RESULT_JSON:",
    "schema": "schemas/result.schema.json"
  },
  "validators": []
}
