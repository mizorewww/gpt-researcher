{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "status",
    "summary",
    "artifacts",
    "quality_gate_passed",
    "target_date",
    "timezone",
    "markets",
    "stock_count"
  ],
  "properties": {
    "status": {"enum": ["completed", "failed"]},
    "summary": {"type": "string", "minLength": 1},
    "artifacts": {"type": "array", "maxItems": 0},
    "quality_gate_passed": {"type": "boolean"},
    "target_date": {"type": "string", "format": "date"},
    "timezone": {"type": "string", "minLength": 1},
    "markets": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [
        {"contains": {"const": "US"}},
        {"contains": {"const": "Japan"}},
        {"contains": {"const": "Korea"}},
        {"contains": {"const": "Hong Kong"}}
      ]
    },
    "stock_count": {"type": "integer", "minimum": 0}
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "completed"}}},
      "then": {
        "properties": {
          "quality_gate_passed": {"const": true},
          "stock_count": {"minimum": 16}
        }
      },
      "else": {
        "properties": {"quality_gate_passed": {"const": false}}
      }
    }
  ]
}
