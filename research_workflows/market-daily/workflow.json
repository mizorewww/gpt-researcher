{
  "$schema": "../workflow.schema.json",
  "schemaVersion": 1,
  "name": "market-daily",
  "description": "Chinese daily market report example using GPT Researcher MCP and a dedicated evidence audit agent.",
  "entryCommand": "run",
  "entryAgent": "market-coordinator",
  "requires": {
    "opencode": ">=1.17.15",
    "env": ["DEEPSEEK_API_KEY", "TAVILY_API_KEY"],
    "skills": ["market-daily-method"],
    "mcp": ["gpt-researcher-codex-long"]
  },
  "execution": {
    "defaultReplicas": 1,
    "maxReplicas": 3,
    "timeoutSeconds": 3000,
    "persistentServer": true
  },
  "security": {
    "allowedToolPatterns": [
      "skill",
      "task",
      "gpt-researcher-codex-long_*"
    ],
    "allowedAgents": ["market-coordinator", "market-auditor"],
    "agentToolPatterns": {
      "market-coordinator": ["skill", "task", "gpt-researcher-codex-long_*"],
      "market-auditor": ["skill"]
    },
    "allowCommandShell": false
  },
  "inputSchema": "schemas/input.schema.json",
  "result": {
    "marker": "OPENCODE_WORKFLOW_RESULT_JSON:",
    "schema": "schemas/result.schema.json"
  },
  "validators": [
    {
      "name": "market-protocol",
      "command": ["{python}", "validators/market_protocol.py"],
      "timeoutSeconds": 60
    }
  ]
}
