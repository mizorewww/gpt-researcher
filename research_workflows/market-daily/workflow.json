{
  "$schema": "../workflow.schema.json",
  "schemaVersion": 1,
  "name": "market-daily",
  "description": "Agent-driven Chinese daily market report using structured Yahoo Finance data and independent web evidence.",
  "entryCommand": "run",
  "entryAgent": "market-coordinator",
  "requires": {
    "opencode": ">=1.17.15",
    "env": ["DEEPSEEK_API_KEY", "TAVILY_API_KEY"],
    "skills": ["market-daily-method"],
    "mcp": ["yfinance", "tavily"]
  },
  "execution": {
    "defaultReplicas": 1,
    "maxReplicas": 3,
    "timeoutSeconds": 3000,
    "persistentServer": true
  },
  "security": {
    "allowedToolPatterns": [
      "skill",
      "task",
      "yfinance_*",
      "tavily_*"
    ],
    "toolCallBudgets": {
      "skill": 12,
      "task": 12,
      "yfinance_*": 180,
      "tavily_*": 40
    },
    "allowedAgents": [
      "market-coordinator",
      "market-data-researcher",
      "market-context-researcher",
      "market-auditor"
    ],
    "agentToolPatterns": {
      "market-coordinator": ["skill", "task", "yfinance_*", "tavily_*"],
      "market-data-researcher": ["skill", "yfinance_*"],
      "market-context-researcher": ["skill", "tavily_*"],
      "market-auditor": ["skill"]
    },
    "allowCommandShell": false
  },
  "inputSchema": "schemas/input.schema.json",
  "result": {
    "marker": "OPENCODE_WORKFLOW_RESULT_JSON:",
    "schema": "schemas/result.schema.json"
  },
  "validators": [
    {
      "name": "market-report-quality",
      "command": ["{python}", "validators/market_report.py"],
      "timeoutSeconds": 60
    }
  ]
}
