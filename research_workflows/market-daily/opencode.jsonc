{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "default_agent": "market-coordinator",
  "instructions": [
    "instructions/evidence-policy.md",
    "instructions/output-contract.md"
  ],
  "permission": {
    "*": "deny",
    "skill": "allow",
    "task": "allow",
    "yfinance_*": "allow",
    "tavily_*": "allow"
  },
  "mcp": {
    "yfinance": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "yfinance-market-mcp==0.3.3",
        "yfinance-mcp"
      ],
      "environment": {
        "UV_CACHE_DIR": "{env:RESEARCH_WORKFLOW_UV_CACHE_DIR}"
      },
      "timeout": 120000,
      "enabled": true
    },
    "tavily": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "tavily-mcp@0.2.21"
      ],
      "environment": {
        "TAVILY_API_KEY": "{env:TAVILY_API_KEY}",
        "NPM_CONFIG_CACHE": "{env:RESEARCH_WORKFLOW_NPM_CACHE_DIR}",
        "DEFAULT_PARAMETERS": "{\"search_depth\":\"advanced\",\"max_results\":6,\"include_raw_content\":false}"
      },
      "timeout": 120000,
      "enabled": true
    }
  }
}
