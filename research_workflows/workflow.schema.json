{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gpt-researcher.local/schemas/opencode-workflow-v1.json",
  "title": "OpenCode Research Workflow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "entryCommand",
    "entryAgent",
    "execution",
    "security",
    "inputSchema",
    "result"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"},
    "description": {"type": "string"},
    "entryCommand": {"type": "string", "minLength": 1},
    "entryAgent": {"type": "string", "minLength": 1},
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "opencode": {"type": "string"},
        "env": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "skills": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "mcp": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultReplicas", "maxReplicas", "timeoutSeconds", "persistentServer"],
      "properties": {
        "defaultReplicas": {"type": "integer", "minimum": 1, "maximum": 32},
        "maxReplicas": {"type": "integer", "minimum": 1, "maximum": 32},
        "timeoutSeconds": {"type": "number", "exclusiveMinimum": 0},
        "persistentServer": {"type": "boolean"}
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedToolPatterns", "allowedAgents", "agentToolPatterns", "allowCommandShell"],
      "properties": {
        "allowedToolPatterns": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "allowedAgents": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "agentToolPatterns": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        },
        "allowCommandShell": {"type": "boolean"}
      }
    },
    "inputSchema": {"type": "string", "minLength": 1},
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["marker", "schema"],
      "properties": {
        "marker": {"type": "string", "minLength": 1},
        "schema": {"type": "string", "minLength": 1}
      }
    },
    "validators": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "timeoutSeconds": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    }
  }
}
