{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "permission": {
    "*": "deny",
    "time_*": "allow",
    "gpt-researcher-codex-long_*": "allow",
    "yfinance_*": "allow"
  },
  "mcp": {
    "time": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-time"
      ],
      "timeout": 30000,
      "enabled": true
    },
    "gpt-researcher-codex-long": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "../..",
        "gpt-researcher"
      ],
      "environment": {
        "CODEX_SEARCH_MODE": "search",
        "CODEX_SEARCH_RETRIEVER_MODE": "search"
      },
      "timeout": 3000000,
      "enabled": true
    },
    "yfinance": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "yfinance-market-mcp==0.3.3",
        "yfinance-mcp"
      ],
      "timeout": 120000,
      "enabled": true
    }
  }
}
